{
  "__inputs": [],
  "__requires": [
    {
      "type": "grafana",
      "id": "grafana",
      "name": "Grafana",
      "version": "11.6.0"
    },
    {
      "type": "prometheus",
      "id": "prometheus",
      "name": "Prometheus",
      "version": "1.0.0"
    }
  ],
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "全池状态概览",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "id": 2,
      "type": "stat",
      "title": "线程池活跃线程",
      "gridPos": { "x": 0, "y": 1, "w": 4, "h": 3 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 30 },
              { "color": "red", "value": 45 }
            ]
          },
          "unit": "short"
        }
      },
      "options": { "colorMode": "background", "graphMode": "none", "textMode": "auto" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "metapool_thread_active_count",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "DB 活跃连接",
      "gridPos": { "x": 4, "y": 1, "w": 4, "h": 3 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 15 },
              { "color": "red", "value": 19 }
            ]
          },
          "unit": "short"
        }
      },
      "options": { "colorMode": "background", "graphMode": "none", "textMode": "auto" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "metapool_db_active_connections",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Redis 活跃连接",
      "gridPos": { "x": 8, "y": 1, "w": 4, "h": 3 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 15 },
              { "color": "red", "value": 19 }
            ]
          },
          "unit": "short"
        }
      },
      "options": { "colorMode": "background", "graphMode": "none", "textMode": "auto" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "metapool_redis_active_connections",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "type": "stat",
      "title": "限流通过/拒绝",
      "gridPos": { "x": 12, "y": 1, "w": 4, "h": 3 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          },
          "unit": "short"
        }
      },
      "options": { "colorMode": "none", "graphMode": "none", "textMode": "value" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(metapool_rate_pass_total[1m])",
          "legendFormat": "通过速率",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(metapool_rate_reject_total[1m])",
          "legendFormat": "拒绝速率",
          "refId": "B"
        }
      ]
    },
    {
      "id": 6,
      "type": "stat",
      "title": "内存池已用 (MB)",
      "gridPos": { "x": 16, "y": 1, "w": 4, "h": 3 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 200 },
              { "color": "red", "value": 240 }
            ]
          },
          "unit": "decbytes"
        }
      },
      "options": { "colorMode": "background", "graphMode": "none", "textMode": "auto" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "metapool_memory_used_bytes",
          "refId": "A"
        }
      ]
    },
    {
      "id": 7,
      "type": "stat",
      "title": "锁竞争计数",
      "gridPos": { "x": 20, "y": 1, "w": 4, "h": 3 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 5 },
              { "color": "red", "value": 10 }
            ]
          },
          "unit": "short"
        }
      },
      "options": { "colorMode": "background", "graphMode": "none", "textMode": "auto" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "metapool_lock_contention_count",
          "refId": "A"
        }
      ]
    },
    {
      "id": 8,
      "type": "row",
      "title": "资源利用率排行",
      "gridPos": { "x": 0, "y": 4, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "各池活跃资源趋势",
      "gridPos": { "x": 0, "y": 5, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 10, "lineWidth": 2, "spanNulls": true },
          "unit": "short"
        }
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "metapool_thread_active_count",
          "legendFormat": "线程池",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "metapool_db_active_connections",
          "legendFormat": "DB 连接池",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "metapool_redis_active_connections",
          "legendFormat": "Redis 连接池",
          "refId": "C"
        }
      ]
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "队列深度对比",
      "gridPos": { "x": 12, "y": 5, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 10, "lineWidth": 2, "spanNulls": true },
          "unit": "short"
        }
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "metapool_thread_queue_size",
          "legendFormat": "线程队列",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "metapool_db_pending_requests",
          "legendFormat": "DB 等待",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "metapool_redis_pending_requests",
          "legendFormat": "Redis 等待",
          "refId": "C"
        }
      ]
    },
    {
      "id": 11,
      "type": "row",
      "title": "告警与异常汇总",
      "gridPos": { "x": 0, "y": 13, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "限流拒绝趋势",
      "gridPos": { "x": 0, "y": 14, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 15, "lineWidth": 2, "spanNulls": true },
          "unit": "short"
        }
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(metapool_rate_reject_total[5m]) * 300",
          "legendFormat": "拒绝数 (5m)",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(metapool_rate_pass_total[5m]) * 300",
          "legendFormat": "通过数 (5m)",
          "refId": "B"
        }
      ]
    },
    {
      "id": 13,
      "type": "timeseries",
      "title": "锁竞争趋势",
      "gridPos": { "x": 12, "y": 14, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 15, "lineWidth": 2, "spanNulls": true },
          "unit": "short"
        }
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "metapool_lock_contention_count",
          "legendFormat": "等待线程数",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(metapool_lock_acquire_total[5m]) * 300",
          "legendFormat": "加锁速率 (5m)",
          "refId": "B"
        }
      ]
    },
    {
      "id": 14,
      "type": "stat",
      "title": "连接泄露总数",
      "gridPos": { "x": 0, "y": 22, "w": 8, "h": 4 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          },
          "unit": "short"
        }
      },
      "options": { "colorMode": "background", "graphMode": "area", "textMode": "auto" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "metapool_db_connection_leak_total + metapool_redis_connection_leak_total",
          "legendFormat": "泄露总数",
          "refId": "A"
        }
      ]
    },
    {
      "id": 15,
      "type": "stat",
      "title": "任务拒绝总数",
      "gridPos": { "x": 8, "y": 22, "w": 8, "h": 4 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          },
          "unit": "short"
        }
      },
      "options": { "colorMode": "background", "graphMode": "area", "textMode": "auto" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "metapool_thread_rejected_total + metapool_rate_reject_total",
          "legendFormat": "拒绝总数",
          "refId": "A"
        }
      ]
    },
    {
      "id": 16,
      "type": "stat",
      "title": "锁获取超时总数",
      "gridPos": { "x": 16, "y": 22, "w": 8, "h": 4 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          },
          "unit": "short"
        }
      },
      "options": { "colorMode": "background", "graphMode": "area", "textMode": "auto" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "metapool_lock_timeout_total",
          "legendFormat": "超时",
          "refId": "A"
        }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["metapool", "global-health"],
  "templating": {
    "list": []
  },
  "time": { "from": "now-15m", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "MetaPool — 全局健康总览",
  "uid": "metapool-global-health",
  "version": 1
}
