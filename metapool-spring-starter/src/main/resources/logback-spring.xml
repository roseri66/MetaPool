<?xml version="1.0" encoding="UTF-8"?>
<!--
    MetaPool 日志配置
    设计要点:
      1. 按环境分 Profile（dev=控制台输出, prod=文件滚动）
      2. MDC 字段: traceId / module / poolName
      3. 第三方框架日志独立控制
      4. 生产环境保留 30 天日志，单文件最大 100MB
-->
<configuration>
    <!-- 默认 pattern -->
    <property name="LOG_PATTERN"
              value="%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] [%X{traceId}] %-5level %logger{36} - %msg%n"/>

    <!-- 开发环境：控制台彩色输出 -->
    <springProfile name="dev">
        <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
            <encoder>
                <pattern>%d{HH:mm:ss.SSS} [%thread] %highlight(%-5level) %cyan(%logger{15}) - %msg%n</pattern>
            </encoder>
        </appender>
        <root level="DEBUG">
            <appender-ref ref="CONSOLE"/>
        </root>
    </springProfile>

    <!-- 生产环境：文件滚动 -->
    <springProfile name="prod">
        <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
            <file>logs/metapool.log</file>
            <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
                <fileNamePattern>logs/metapool.%d{yyyy-MM-dd}.%i.log</fileNamePattern>
                <maxHistory>30</maxHistory>
                <totalSizeCap>3GB</totalSizeCap>
            </rollingPolicy>
            <encoder>
                <pattern>${LOG_PATTERN}</pattern>
            </encoder>
        </appender>
        <root level="INFO">
            <appender-ref ref="FILE"/>
        </root>
    </springProfile>

    <!-- 第三方框架日志降噪 -->
    <logger name="net.bytebuddy" level="WARN"/>
    <logger name="io.micrometer" level="WARN"/>
    <logger name="io.lettuce" level="WARN"/>
</configuration>
